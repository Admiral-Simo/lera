<div class="max-w-md mx-auto mt-8 px-4">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">Edit product</h1>

    <%= link_to products_path, class: "inline-flex items-center gap-1 text-sm font-medium text-slate-500 hover:text-slate-700 transition" do %>
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Cancel
    <% end %>
  </div>

  <%= render "form", product: @product %>
</div>
