<div class="space-y-4">
  <% if product.inventory_count.positive? %>
    <div class="flex items-center gap-2">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <p class="text-sm font-semibold text-emerald-700">
        <%= product.inventory_count %> in stock
      </p>
    </div>

  <% else %>
    <div class="space-y-4">
      <div class="flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-rose-500"></span>
        <p class="text-sm font-bold text-rose-600 tracking-wide uppercase">
          Out of stock
        </p>
      </div>

      <div class="bg-slate-50 border border-slate-100 rounded-2xl p-4 sm:p-5 space-y-3.5">
        <div>
          <p class="text-sm font-semibold text-slate-900">Email me when available</p>
          <p class="text-xs text-slate-500 mt-0.5">We'll drop you a line the moment this item is restocked.</p>
        </div>

        <%= form_with model: [product, Subscriber.new], class: "flex flex-col sm:flex-row gap-2" do |form| %>
          <div class="relative flex-grow">
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5">
              <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25H4.5A2.25 2.25 0 012.25 17.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5H4.5a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>

            <%= form.email_field :email,
                  placeholder: "you@example.com",
                  required: true,
                  class: "block w-full rounded-xl border border-slate-200 bg-white py-2.5 pl-10 pr-3 text-sm text-slate-900 placeholder-slate-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 focus:outline-none transition-all shadow-sm" %>
          </div>

          <%= form.submit "Notify Me",
                class: "cursor-pointer whitespace-nowrap inline-flex justify-center items-center rounded-xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 transition active:scale-[0.98]" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
