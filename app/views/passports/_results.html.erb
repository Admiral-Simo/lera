<h3>Extraction Output</h3>

<% if local_assigns[:mrz_lines].present? %>
  <p style="color: #2b7a4b; font-size: 14px; font-weight: bold;">✓ 2 Lines Isolated Successfully</p>
  <div style="background: #212529; color: #f8f9fa; padding: 20px; border-radius: 6px; font-family: monospace; font-size: 15px; letter-spacing: 1px; overflow-x: auto; box-shadow: inset 0 0 10px rgba(0,0,0,0.5);">
    <% mrz_lines.each_with_index do |line, idx| %>
      <div style="margin-bottom: 8px;">
        <span style="color: #6c757d; user-select: none; margin-right: 10px;"><%= idx + 1 %></span><%= line %>
      </div>
    <% end %>
  </div>
  <p style="font-size: 12px; color: #6c757d; margin-top: 10px;">Ready to be forwarded into your core validation parser.</p>
<% else %>
  <div style="border: 2px dashed #dee2e6; border-radius: 6px; height: 160px; display: flex; align-items: center; justify-content: center; color: #adb5bd; text-align: center;">
    Upload a valid image file on the left<br>to view extracted OCR results.
  </div>
<% end %>
