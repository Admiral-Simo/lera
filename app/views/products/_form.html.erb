<%= form_with model: product, class: "space-y-6 max-w-md mx-auto p-6 bg-white rounded-xl shadow-md border border-slate-100" do |form| %>

  <% if form.object.errors.any? %>
    <div class="p-4 rounded-lg bg-red-50 border border-red-200" role="alert">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm font-medium text-red-800">
            <%= form.object.errors.full_messages.first %>
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="flex flex-col gap-1.5">
    <%= form.label :name, class: "text-sm font-semibold text-slate-700" %>
    <%= form.text_field :name,
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-slate-900 placeholder-slate-400 shadow-sm transition duration-150 ease-in-out focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20 text-sm" %>
  </div>

  <div class="flex flex-col gap-1.5">
    <%= form.label :description, class: "text-sm font-semibold text-slate-700" %>
    <%= form.rich_textarea :description %>
  </div>

  <div>
    <%= form.label :featured_image, style: "display: block" %>
    <%= form.file_field :featured_image, accept: "image/*" %>
  </div>

  <div>
    <%= form.label :inventory_count, style: "display: block" %>
    <%= form.number_field :inventory_count %>
  </div>

  <div class="pt-2">
    <%= form.submit class: "w-full cursor-pointer justify-center rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition duration-150 ease-in-out hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 active:bg-blue-700" %>
  </div>

<% end %>
