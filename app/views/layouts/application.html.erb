<!DOCTYPE html>
<html class="h-full bg-slate-50 text-slate-900">
  <head>
    <title><%= content_for(:title) || "Fast Saas" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Fast Saas">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link class="rounded-lg" rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full antialiased flex flex-col relative">

    <div class="fixed top-4 right-4 z-50 space-y-3 w-full max-w-sm px-4 sm:px-0 pointer-events-none">

      <% if flash[:notice].present? %>
        <div class="flash-toast pointer-events-auto bg-white rounded-2xl border border-emerald-100 shadow-xl shadow-slate-200/50 p-4 flex items-start gap-3 transform translate-y-0 transition-all duration-300 animate-in fade-in slide-in-from-top-4">
          <div class="flex-shrink-0 text-emerald-500 mt-0.5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-semibold text-slate-900">Success</p>
            <p class="text-xs text-slate-500 mt-0.5 leading-relaxed"><%= flash[:notice] %></p>
          </div>
          <button onclick="this.closest('.flash-toast').remove()" class="cursor-pointer text-slate-400 hover:text-slate-600 rounded-lg p-0.5 hover:bg-slate-50 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      <% end %>

      <% if flash[:alert].present? %>
        <div class="flash-toast pointer-events-auto bg-white rounded-2xl border border-rose-100 shadow-xl shadow-slate-200/50 p-4 flex items-start gap-3 transform translate-y-0 transition-all duration-300 animate-in fade-in slide-in-from-top-4">
          <div class="flex-shrink-0 text-rose-500 mt-0.5">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
            </svg>
          </div>
          <div class="flex-1">
            <p class="text-sm font-semibold text-slate-900">Attention Required</p>
            <p class="text-xs text-slate-500 mt-0.5 leading-relaxed"><%= flash[:alert] %></p>
          </div>
          <button onclick="this.closest('.flash-toast').remove()" class="cursor-pointer text-slate-400 hover:text-slate-600 rounded-lg p-0.5 hover:bg-slate-50 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      <% end %>

    </div>

    <header class="sticky top-0 z-40 w-full border-b border-slate-200 bg-white/80 backdrop-blur-md">
      <nav class="mx-auto flex max-w-7xl h-16 items-center justify-between px-4 sm:px-6 lg:px-8" aria-label="Global">
        <div class="flex items-center gap-2">
          <div class="h-8 w-8 rounded-lg bg-blue-600 flex items-center justify-center font-bold text-white text-sm tracking-wider">
            FS
          </div>
          <%= link_to "Fast Saas", root_path, class: "text-base font-semibold tracking-tight text-slate-900 hover:text-blue-600 transition" %>
        </div>

        <div class="flex items-center gap-4">
          <% if authenticated? %>
            <div class="flex items-center gap-3">
              <span class="text-xs text-slate-400 hidden sm:inline">Active Session</span>
              <%= button_to session_path, method: :delete, class: "cursor-pointer rounded-lg border border-slate-200 bg-white px-3 py-1.5 text-xs font-semibold text-slate-600 shadow-sm transition hover:bg-slate-50 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600" do %>
                Log out
              <% end %>
            </div>
          <% else %>
            <%= link_to "Log in", new_session_path, class: "text-sm font-semibold text-blue-600 hover:text-blue-500 transition" %>
          <% end %>
        </div>
      </nav>
    </header>

    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <%= yield %>
    </main>

  </body>
</html>
